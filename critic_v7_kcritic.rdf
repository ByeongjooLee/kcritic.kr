<?xml version='1.0' encoding='utf-8'?>
<!--
    ===================================================================================
    온톨로지 개요 (Ontology Overview)
    ===================================================================================

    명칭  : 김우창·유종호 문학비평 온톨로지 (Literary Criticism Ontology)
    약어  : critic
    기반 URI : http://kcritic.kr/ontology/critic#
    작성일 : 2026-05-26
    버전  : 7.0-kcritic (수정일: 2026-06-08)
    작성자 : 이병주

    ── v6 → v7 변경 ─────────────────────────────────────────────────────────────────
    핵심 추가: 이론가 인물 속성 강화
      - critic:Role 클래스 추가 — 인물의 학문적 역할(철학자·문학비평가 등)
      - critic:hasRole ObjectProperty 추가 (Person → Role, 복수 부여 가능)
      - critic:nationality DatatypeProperty 추가 (문학·사상사적 귀속 국가, 출생국 아님 — 예: 엘리엇→영국, 크리스테바→프랑스)
      - 이론가 143명 전원에 nationality + hasRole 부여

    ── 클래스 계층 ───────────────────────────────────────────────────────────────────
    owl:Thing
    ├── critic:Agent                           행위주체 (≡ foaf:Agent)
    │   └── critic:Person                      사람 (≡ foaf:Person)
    │       ├── critic:Critic                  비평가
    │       ├── critic:Thinker                 이론가·사상가 (인용 대상)
    │       └── (critic:Person)                작가 (비평 대상)
    ├── critic:Document                        문서 (≡ foaf:Document)
    │   └── critic:CriticalEssay               비평문
    └── critic:Role                            인물 역할 (philosopher, poet 등)

    ── 핵심 관계 ─────────────────────────────────────────────────────────────────────
    critic:analyzes          비평가(Critic) → 사람(Person)     "김우창이 윤동주를 비평했다"
    critic:hasRole           사람(Person) → 역할(Role)         "하이데거는 철학자다"
    cito:discusses           비평문 → 사람(작가)               "이 비평문이 윤동주를 다룬다"
    cito:citesAsAuthority    비평문 → Thinker(이론가)          "이 비평문이 하버마스를 인용했다"
    dcterms:creator          비평문 → 비평가                   "이 비평문은 김우창이 썼다"

    ── 통계 (v7) ────────────────────────────────────────────────────────────────────
    클래스: 7개 (Agent, Person, Document, Critic, Thinker, CriticalEssay, Role)
    OWL 정렬: critic:Agent ≡ foaf:Agent, critic:Person ≡ foaf:Person, critic:Document ≡ foaf:Document
    자체 ObjectProperty: 2개 (critic:analyzes, critic:hasRole)
    재사용 ObjectProperty: 3개 (cito:discusses, cito:citesAsAuthority, dcterms:creator)
    자체 DataProperty: 2개 (critic:name ≡ foaf:name, critic:nationality)
    재사용 DataProperty: 2개 (dcterms:title, dcterms:date)
    비평가 개인: 2명 (김우창, 유종호)
    이론가 개인: 143명
    비평문 개인: 48편
    이론가 인용 트리플: 192개
    Role 인스턴스: 10개
    nationality 트리플: 143개

    ── 선행 온톨로지 참조 ──────────────────────────────────────────────────────────
    CiTO         https://sparontologies.github.io/cito/current/cito.html
    Dublin Core  https://www.dublincore.org/specifications/dublin-core/dcmi-terms/
    FOAF         http://xmlns.com/foaf/0.1/spec/  (OWL 정렬용 — import 없음)
    Wikidata     https://www.wikidata.org/
    ===================================================================================
-->

<rdf:RDF
  xmlns:cito="http://purl.org/spar/cito/"
  xmlns:critic="http://kcritic.kr/ontology/critic#"
  xmlns:dcterms="http://purl.org/dc/terms/"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xml:base="http://kcritic.kr/ontology/">

  <owl:Ontology rdf:about="http://kcritic.kr/ontology/">
    <rdfs:label xml:lang="ko">한국 비평사 온톨로지 — 김우창·유종호</rdfs:label>
    <rdfs:comment xml:lang="ko">한국 문학비평에서 "누가·누구를·어떻게·어떤 이론으로" 비평했는가를 표현하는 온톨로지 (v7-kcritic)</rdfs:comment>
    <owl:versionInfo>7.0-kcritic</owl:versionInfo>
  </owl:Ontology>

  <!-- ============================================================
       Object Properties
       ============================================================ -->

  <owl:ObjectProperty rdf:about="http://kcritic.kr/ontology/critic#analyzes">
    <rdfs:domain rdf:resource="http://kcritic.kr/ontology/critic#Critic" />
    <rdfs:range rdf:resource="http://kcritic.kr/ontology/critic#Person" />
    <rdfs:label xml:lang="ko">~을 비평하다</rdfs:label>
    <rdfs:comment xml:lang="ko">비평가가 특정 인물을 비평 대상으로 삼는 관계. 이 온톨로지의 핵심 관계.</rdfs:comment>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://kcritic.kr/ontology/critic#hasRole">
    <rdfs:domain rdf:resource="http://kcritic.kr/ontology/critic#Person" />
    <rdfs:range rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <rdfs:label xml:lang="ko">역할을 갖다</rdfs:label>
    <rdfs:comment xml:lang="ko">인물이 학문적·문학적 역할을 갖는 관계. 한 인물에 복수 역할 부여 가능.</rdfs:comment>
  </owl:ObjectProperty>

  <!-- ──────────────────────────────────────────────────────────────
       재사용 외부 ObjectProperty (재선언 없이 URI만으로 사용)
       ──────────────────────────────────────────────────────────────
       dcterms:creator
         설명 : 비평문의 저자(작성자)를 가리키는 관계. 비평문 → 비평가.
         출처 : Dublin Core Metadata Terms
         URI  : http://purl.org/dc/terms/creator

       cito:discusses
         설명 : 비평문이 특정 인물(작가·비평 대상)을 논의 대상으로 다루는 관계. 비평문 → Person.
         출처 : Citation Typing Ontology (CiTO)
         URI  : http://purl.org/spar/cito/discusses

       cito:citesAsAuthority
         설명 : 비평문이 특정 이론가·사상가를 이론적 권위로 인용하는 관계. 비평문 → Thinker.
         출처 : Citation Typing Ontology (CiTO)
         URI  : http://purl.org/spar/cito/citesAsAuthority
       ────────────────────────────────────────────────────────────── -->

  <!-- ============================================================
       Datatype Properties
       ============================================================ -->

  <owl:DatatypeProperty rdf:about="http://kcritic.kr/ontology/critic#name">
    <rdfs:domain rdf:resource="http://kcritic.kr/ontology/critic#Person" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:label xml:lang="ko">이름</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 이름. 언어 태그(xml:lang)로 한국어·영어 병기 가능.</rdfs:comment>
    <owl:equivalentProperty rdf:resource="http://xmlns.com/foaf/0.1/name" />
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://kcritic.kr/ontology/critic#nationality">
    <rdfs:domain rdf:resource="http://kcritic.kr/ontology/critic#Person" />
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:label xml:lang="ko">국적</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 문학·사상사적 귀속 국가. 출생국이 아니라 해당 인물이 주로 귀속되는 사상 전통의 국가를 한국어로 기재 (예: T.S. 엘리엇→영국, 줄리아 크리스테바→프랑스). Wikidata에 없는 인물을 위해 온톨로지에 직접 입력.</rdfs:comment>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/title">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string" />
    <rdfs:label xml:lang="ko">제목</rdfs:label>
    <rdfs:comment xml:lang="ko">비평문의 제목. Dublin Core에서 재사용.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="http://purl.org/dc/terms/title" />
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/date">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#gYear" />
    <rdfs:label xml:lang="ko">발표 연도</rdfs:label>
    <rdfs:comment xml:lang="ko">비평문의 발표 연도. Dublin Core에서 재사용.</rdfs:comment>
    <rdfs:seeAlso rdf:resource="http://purl.org/dc/terms/date" />
  </owl:DatatypeProperty>

  <!-- ============================================================
       Classes
       ============================================================ -->

  <owl:Class rdf:about="http://kcritic.kr/ontology/critic#Agent">
    <rdfs:label xml:lang="ko">행위주체</rdfs:label>
    <rdfs:comment xml:lang="ko">행위 능력을 갖는 존재의 최상위 클래스.</rdfs:comment>
    <owl:equivalentClass rdf:resource="http://xmlns.com/foaf/0.1/Agent" />
  </owl:Class>

  <owl:Class rdf:about="http://kcritic.kr/ontology/critic#Person">
    <rdfs:subClassOf rdf:resource="http://kcritic.kr/ontology/critic#Agent" />
    <rdfs:label xml:lang="ko">사람</rdfs:label>
    <rdfs:comment xml:lang="ko">비평 행위와 관련되는 모든 인물의 상위 클래스. critic:Critic, critic:Thinker의 상위.</rdfs:comment>
    <owl:equivalentClass rdf:resource="http://xmlns.com/foaf/0.1/Person" />
  </owl:Class>

  <owl:Class rdf:about="http://kcritic.kr/ontology/critic#Document">
    <rdfs:label xml:lang="ko">문서</rdfs:label>
    <rdfs:comment xml:lang="ko">텍스트 문서의 상위 클래스. critic:CriticalEssay의 상위.</rdfs:comment>
    <owl:equivalentClass rdf:resource="http://xmlns.com/foaf/0.1/Document" />
  </owl:Class>

  <owl:Class rdf:about="http://kcritic.kr/ontology/critic#Critic">
    <rdfs:subClassOf rdf:resource="http://kcritic.kr/ontology/critic#Person" />
    <rdfs:label xml:lang="ko">비평가</rdfs:label>
    <rdfs:comment xml:lang="ko">비평 행위의 주체. critic:analyzes 관계의 domain.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kcritic.kr/ontology/critic#Thinker">
    <rdfs:subClassOf rdf:resource="http://kcritic.kr/ontology/critic#Person" />
    <rdfs:label xml:lang="ko">이론가·사상가</rdfs:label>
    <rdfs:comment xml:lang="ko">비평문에서 이론적 권위로 인용되는 철학자·이론가·사상가. cito:citesAsAuthority 관계의 range.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kcritic.kr/ontology/critic#Writer">
    <rdfs:subClassOf rdf:resource="http://kcritic.kr/ontology/critic#Person" />
    <rdfs:label xml:lang="ko">작가</rdfs:label>
    <rdfs:comment xml:lang="ko">비평의 대상이 되는 시인·소설가·문인. cito:discusses 관계의 range.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kcritic.kr/ontology/critic#CriticalEssay">
    <rdfs:subClassOf rdf:resource="http://kcritic.kr/ontology/critic#Document" />
    <rdfs:label xml:lang="ko">비평문</rdfs:label>
    <rdfs:comment xml:lang="ko">비평가가 집필한 개별 비평 에세이.</rdfs:comment>
  </owl:Class>

  <owl:Class rdf:about="http://kcritic.kr/ontology/critic#Role">
    <rdfs:label xml:lang="ko">역할</rdfs:label>
    <rdfs:comment xml:lang="ko">인물의 학문적·문학적 역할. critic:hasRole의 range. 한 인물이 복수의 역할을 가질 수 있다(예: 사르트르 — 철학자이자 소설가이자 비평가).</rdfs:comment>
  </owl:Class>

  <!-- ============================================================
       역할 (Role) Individuals
       ============================================================ -->

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/philosopher">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">철학자</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/literary-critic">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">문학비평가</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/poet">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">시인</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/novelist">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">소설가</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/sociologist">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">사회학자</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/psychologist">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">심리학자</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/political-theorist">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">정치이론가</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/historian">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">역사학자</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/linguist">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">언어학자</critic:name>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/role/aesthetician">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Role" />
    <critic:name xml:lang="ko">미학자</critic:name>
  </owl:NamedIndividual>

  <!-- ============================================================
       비평가 (Critic) Individuals
       ============================================================ -->

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/김우창">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Critic" />
    <critic:name xml:lang="ko">김우창</critic:name>
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q12595024" />
    <owl:sameAs rdf:resource="https://encykorea.aks.ac.kr/Article/E0010002" />
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/유종호">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Critic" />
    <critic:name xml:lang="ko">유종호</critic:name>
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q13564819" />
    <owl:sameAs rdf:resource="http://lod.nl.go.kr/resource/KAC201106284" />
  </owl:NamedIndividual>

  <!-- ============================================================
       이론가·사상가 (Thinker) Individuals
       ============================================================ -->

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/T.S.엘리엇">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Thinker" />
    <critic:name xml:lang="ko">T. S. 엘리엇</critic:name>
    <critic:name xml:lang="en">T. S. Eliot</critic:name>
    <critic:nationality>영국</critic:nationality>
    <critic:hasRole rdf:resource="http://kcritic.kr/ontology/role/poet" />
    <critic:hasRole rdf:resource="http://kcritic.kr/ontology/role/literary-critic" />
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q37767" />
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/I.A.리처즈">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Thinker" />
    <critic:name xml:lang="ko">I. A. 리처즈</critic:name>
    <critic:name xml:lang="en">I. A. Richards</critic:name>
    <critic:nationality>영국</critic:nationality>
    <critic:hasRole rdf:resource="http://kcritic.kr/ontology/role/literary-critic" />
