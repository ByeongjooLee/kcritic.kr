  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/데카르트">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Thinker" />
    <critic:name xml:lang="ko">데카르트</critic:name>
    <critic:name xml:lang="en">René Descartes</critic:name>
    <critic:nationality>프랑스</critic:nationality>
    <critic:hasRole rdf:resource="http://kcritic.kr/ontology/role/philosopher" />
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q9191" />
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/도스토옙스키">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Thinker" />
    <critic:name xml:lang="ko">도스토옙스키</critic:name>
    <critic:name xml:lang="en">Fyodor Dostoevsky</critic:name>
    <critic:nationality>러시아</critic:nationality>
    <critic:hasRole rdf:resource="http://kcritic.kr/ontology/role/novelist" />
    <owl:sameAs rdf:resource="http://www.wikidata.org/entity/Q991" />
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://kcritic.kr/ontology/뒤르켐">
    <rdf:type rdf:resource="http://kcritic.kr/ontology/critic#Thinker" />
    <critic:name xml:lang="ko">뒤르켐</critic:name>
    <critic:name xml:lang="en">Émile Durkheim</critic:name>
    <critic:nationality>프랑스</critic:nationality>
